diff --git a/ai_scientist/treesearch/utils/metric.py b/ai_scientist/treesearch/utils/metric.py
index e73f0c5..1dcf44f 100644
--- a/ai_scientist/treesearch/utils/metric.py
+++ b/ai_scientist/treesearch/utils/metric.py
@@ -338,3 +338,44 @@ class WorstMetricValue(MetricValue):
 
     def __str__(self):
         return super().__str__()
+
+
+def is_degenerate_metric(metric, sat_hi=0.98, sat_lo=0.02):
+    """Signal channel for node evaluation: True if an accuracy-class metric is
+    degenerate (saturated >= sat_hi or collapsed <= sat_lo so no effect is
+    measurable across conditions). Reads only the MetricValue a node already
+    has -- no re-run, no file I/O. Conservative: returns False whenever it
+    cannot tell, so it never vetoes a node it does not understand.
+    """
+    if metric is None:
+        return False
+    val = getattr(metric, "value", None)
+    if val is None:
+        return False
+
+    def _norm(x):
+        return x / 100.0 if x > 1.5 else float(x)
+
+    finals = []
+    if isinstance(val, dict) and "metric_names" in val:
+        for mn in val.get("metric_names", []):
+            if mn.get("lower_is_better"):
+                continue
+            name = str(mn.get("metric_name", "")).lower()
+            if not any(t in name for t in ("acc", "f1", "auc")):
+                continue
+            for d in mn.get("data", []):
+                fv = d.get("final_value", d.get("best_value"))
+                if isinstance(fv, (int, float)) and not isinstance(fv, bool):
+                    finals.append(_norm(fv))
+    elif isinstance(val, dict):
+        for v in val.values():
+            if isinstance(v, (int, float)) and not isinstance(v, bool):
+                finals.append(_norm(v))
+    elif isinstance(val, (int, float)) and not isinstance(val, bool):
+        finals.append(_norm(val))
+
+    if not finals:
+        return False
+    saturated = sum(1 for f in finals if f >= sat_hi or f <= sat_lo)
+    return saturated / len(finals) > 0.5
