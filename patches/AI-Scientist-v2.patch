+def _extract_latex_block(text):
+    """Extract a full LaTeX document from an LLM response, robust to reasoning
+    models (e.g. gpt-5.x) that omit the ```latex fence. Tries, in order: a
+    ```latex ... ``` block, a generic fenced block containing \\documentclass,
+    then a raw \\documentclass ... \\end{document} body. Returns the stripped
+    LaTeX string, or None if nothing usable is found."""
+    if not text:
+        return None
+    m = re.search(r"```latex(.*?)```", text, re.DOTALL)
+    if m:
+        return m.group(1).strip()
+    m = re.search(r"```(?:tex)?\s*(\\documentclass.*?)```", text, re.DOTALL)
+    if m:
+        return m.group(1).strip()
+    m = re.search(r"(\\documentclass.*?\\end\{document\})", text, re.DOTALL)
+    if m:
+        return m.group(1).strip()
+    return None
+
+
