+def repair_invalid_figures(latex_code, available_figs, fuzzy_cutoff=0.6):
+    """P2: deterministic post-processing of figure references that point at a
+    file the aggregator never produced (the #1 source of `Figure ??` + 0
+    embedded images).
+
+    For each `\\includegraphics{X}` whose basename is not in available_figs:
+      1. fuzzy-map X to the closest real filename on disk (>= fuzzy_cutoff);
+         rewrite the path in place; OR
+      2. if no close match exists, delete that `\\includegraphics`. If the
+         deletion empties a surrounding `figure`/`subfigure` environment (no
+         remaining graphics), remove the whole environment so we do not leave an
+         empty floating box.
+
+    Operates purely on text — no LLM, no compile — so it always runs and is
+    idempotent. Returns (new_latex, n_remapped, n_deleted).
+    """
+    import difflib
+
+    avail = list(available_figs)
+    avail_lower = {a.lower(): a for a in avail}
+    n_remapped = 0
+    n_deleted = 0
+
+    inc_re = re.compile(r"\\includegraphics(?:\[[^\]]*\])?\{([^}]+)\}")
+
+    def _tok(s):
+        # tokens of the filename STEM (drop extension + the bare word 'png'/'pdf'
+        # so the image format is never counted as a shared token).
+        stem = os.path.splitext(s)[0]
+        return set(t for t in re.split(r"[^a-z0-9]+", stem.lower())
+                   if len(t) > 2 and t not in ("png", "pdf", "jpg", "jpeg", "fig"))
+
+    def resolve(path):
+        """Return (action, value): ('keep', path) | ('remap', newpath) |
+        ('drop', None)."""
+        base = os.path.basename(path)
+        if base in avail or path in avail:
+            return ("keep", path)
+        # already a real file basename? keep.
+        if base.lower() in avail_lower:
+            return ("remap", path.replace(base, avail_lower[base.lower()]))
+        # LaTeX demo placeholders are always valid (shipped with graphicx).
+        if base.startswith("example-image"):
+            return ("keep", path)
+        # 1) close string match
+        match = difflib.get_close_matches(base, avail, n=1, cutoff=fuzzy_cutoff)
+        if match:
+            return ("remap", path.replace(base, match[0]) if base in path
+                    else match[0])
+        # 2) token-overlap fallback: prefer keeping a real (if imperfectly
+        #    named) figure over deleting it + leaving a dangling \ref. Pick the
+        #    available file sharing the most filename tokens (>=1 shared).
+        bt = _tok(base)
+        best, best_score = None, 0
+        for a in avail:
+            score = len(bt & _tok(a))
+            if score > best_score:
+                best, best_score = a, score
+        if best and best_score >= 1:
+            return ("remap", path.replace(base, best) if base in path else best)
+        return ("drop", None)
+
+    # First pass: classify every includegraphics.
+    to_drop_spans = []  # (start, end) of includegraphics commands to delete
+    out = latex_code
+    # Work on a list of (span, action, newpath) using finditer on the ORIGINAL.
+    edits = []
+    for m in inc_re.finditer(latex_code):
+        action, val = resolve(m.group(1))
+        if action == "keep":
+            continue
+        if action == "remap":
+            new_cmd = m.group(0).replace("{" + m.group(1) + "}", "{" + val + "}")
+            edits.append(("remap", m.start(), m.end(), new_cmd))
+            n_remapped += 1
+        else:
+            edits.append(("drop", m.start(), m.end(), ""))
+
+    if not edits:
+        return latex_code, 0, 0
+
+    # Apply edits back-to-front so offsets stay valid.
+    for kind, s, e, repl in sorted(edits, key=lambda x: x[1], reverse=True):
+        if kind == "remap":
+            out = out[:s] + repl + out[e:]
+        else:
+            out = out[:s] + "" + out[e:]
+            n_deleted += 1
+
+    # Second pass: drop now-empty figure / subfigure environments (no graphics
+    # left inside). Run until stable to catch nested cases. Harvest the \label
+    # keys of removed environments so we can neutralize dangling \ref's that
+    # would otherwise render as `??`.
+    env_re = re.compile(
+        r"\\begin\{(figure\*?|subfigure)\}(?:\[[^\]]*\])?.*?\\end\{\1\}",
+        re.DOTALL,
+    )
+    label_re = re.compile(r"\\label\{([^}]+)\}")
+    orphaned_labels = set()
+    changed = True
+    while changed:
+        changed = False
+        new_out = []
+        last = 0
+        for m in env_re.finditer(out):
+            body = m.group(0)
+            if "\\includegraphics" not in body:
+                for lm in label_re.finditer(body):
+                    orphaned_labels.add(lm.group(1))
+                new_out.append(out[last:m.start()])
+                last = m.end()
+                changed = True
+        new_out.append(out[last:])
+        out = "".join(new_out)
+
+    # Third pass: clean up dangling references to deleted figure labels so they
+    # do not compile to `??`. Remove an optional leading "Figure~"/"Fig. " word,
+    # the \ref command, and a trailing comma/space if it leaves a dangling one.
+    n_refs_cleaned = 0
+    for lbl in orphaned_labels:
+        lbl_esc = re.escape(lbl)
+        # "(see Figure~\ref{lbl})" / "Figure \ref{lbl}" / "\autoref{lbl}" etc.
+        ref_phrase = re.compile(
+            r"\s*\(?\s*(?:see\s+)?(?:Figure|Fig\.?|Table|Tab\.?)?~?\s*"
+            r"\\(?:auto|c|eq)?ref\{" + lbl_esc + r"\}\s*\)?",
+            re.IGNORECASE,
+        )
+        new_out, k = ref_phrase.subn(" ", out)
+        if k:
+            out = new_out
+            n_refs_cleaned += k
+    if n_refs_cleaned:
+        # tidy doubled spaces / space-before-punct introduced by removals
+        out = re.sub(r"[ \t]{2,}", " ", out)
+        out = re.sub(r"\s+([.,;:])", r"\1", out)
+
+    return out, n_remapped, n_deleted
+
+
+# Blocking LaTeX problems that must NOT be left in the final PDF. If template.log
+# still shows any of these, the reflection loop is forced to keep fixing.
+_BLOCKING_LOG_PATTERNS = [
+    r"! Undefined control sequence",
+    r"! Missing \$ inserted",
+    r"! LaTeX Error",
+    r"Undefined references",
+    r"There were undefined references",
+    r"Citation .* undefined",
+    r"Reference .* undefined",
+]
+
+
+def latex_blocking_errors(latex_folder, log_name="template.log"):
+    """P3: scan the pdflatex log for blocking errors / unresolved cross-refs so
+    the reflection loop is not allowed to early-exit on a still-broken document.
+
+    Returns a list of short error tags found (empty == clean). Unresolved `??`
+    surface as 'Undefined references'/'... undefined' in the .log even though the
+    run is nonstopmode and returns rc=0, so we key off the log, not the rc."""
+    log_path = osp.join(latex_folder, log_name)
+    if not osp.exists(log_path):
+        return []
+    try:
+        with open(log_path, "r", errors="ignore") as f:
+            text = f.read()
+    except OSError:
+        return []
+    found = []
+    for pat in _BLOCKING_LOG_PATTERNS:
+        m = re.search(pat, text)
+        if m:
+            found.append(m.group(0)[:80])
+    return found
+
