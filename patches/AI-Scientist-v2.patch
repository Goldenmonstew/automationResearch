index 0000000..d2b6fc5
--- /dev/null
+++ b/ai_scientist/tools/openalex_search.py
@@ -0,0 +1,112 @@
+"""OpenAlex-backed drop-in replacement for tools.semantic_scholar.search_for_papers.
+
+Why: the self-hosted setup has no Semantic Scholar API key (S2 returns 429 and
+citations come out as "(?)"), and export.arxiv.org is not reachable from the GPU
+server. OpenAlex (https://api.openalex.org) is free, needs no key, IS reachable,
+and returns rich metadata. We reshape its response into the EXACT dict structure
+the v2 writeup expects: each paper has title/authors/venue/year/abstract plus
+citationStyles.bibtex (which OpenAlex does not provide, so we synthesize it).
+"""
+import os
+import re
+import time
+import warnings
+from typing import Dict, List, Optional, Union
+
+import backoff
+import requests
+
+OPENALEX_BASE = "https://api.openalex.org/works"
+# OpenAlex "polite pool" — a contact email yields higher, more stable rate limits.
+MAILTO = os.getenv("OPENALEX_MAILTO", "ai-scientist@example.com")
+
+
+def _reconstruct_abstract(inv_index: Optional[dict]) -> str:
+    """OpenAlex returns abstract as an inverted index {word: [positions]}."""
+    if not inv_index:
+        return ""
+    positions = {}
+    for word, idxs in inv_index.items():
+        for i in idxs:
+            positions[i] = word
+    if not positions:
+        return ""
+    text = " ".join(positions[i] for i in range(max(positions) + 1) if i in positions)
+    return text[:1500]  # keep prompt context bounded
+
+
+def _clean(s: str) -> str:
+    return (s or "").replace("{", "").replace("}", "").strip()
+
+
+def _make_bibtex(work: dict, names: List[str], venue: str) -> str:
+    year = work.get("publication_year") or ""
+    title = _clean(work.get("title") or "")
+    doi = (work.get("doi") or "").replace("https://doi.org/", "")
+    author_field = " and ".join(names) if names else "Unknown"
+    first_last = names[0].split()[-1] if names else "anon"
+    first_word = re.sub(r"[^A-Za-z]", "", (title.split()[0] if title else "paper")) or "ref"
+    key = re.sub(r"[^A-Za-z0-9]", "", f"{first_last}{year}{first_word}").lower() or "ref"
+    # entry type: inproceedings if the venue looks like a conference/workshop
+    is_conf = bool(re.search(r"conference|workshop|proceedings|symposium|meeting", venue, re.I))
+    etype = "inproceedings" if is_conf else "article"
+    field = "booktitle" if is_conf else "journal"
+    lines = [f"@{etype}{{{key},"]
+    lines.append(f" title = {{{title}}},")
+    lines.append(f" author = {{{author_field}}},")
+    if venue:
+        lines.append(f" {field} = {{{_clean(venue)}}},")
+    if year:
+        lines.append(f" year = {{{year}}},")
+    if doi:
+        lines.append(f" doi = {{{doi}}},")
+    lines.append("}")
+    return "\n".join(lines)
+
+
+@backoff.on_exception(
+    backoff.expo, requests.exceptions.RequestException, max_tries=5
+)
+def search_for_papers(query, result_limit=10) -> Union[None, List[Dict]]:
+    if not query:
+        return None
+    rsp = requests.get(
+        OPENALEX_BASE,
+        params={
+            "search": query,
+            "per-page": result_limit,
+            "mailto": MAILTO,
+            "sort": "relevance_score:desc",
+        },
+        timeout=30,
+    )
+    print(f"OpenAlex Status: {rsp.status_code} (query={query[:60]!r})")
+    rsp.raise_for_status()
+    works = rsp.json().get("results", [])
+    if not works:
+        return None
+    papers: List[Dict] = []
+    for w in works:
+        authorships = w.get("authorships", []) or []
+        names = [
+            a.get("author", {}).get("display_name", "")
+            for a in authorships
+            if a.get("author")
+        ]
+        names = [n for n in names if n][:10]
+        pl = w.get("primary_location") or {}
+        src = (pl.get("source") or {}) if pl else {}
+        venue = src.get("display_name") or ""
+        papers.append(
+            {
+                "title": _clean(w.get("title") or ""),
+                "authors": ", ".join(names[:8]) or "Unknown",
+                "venue": venue or "n/a",
+                "year": w.get("publication_year") or "",
+                "abstract": _reconstruct_abstract(w.get("abstract_inverted_index")),
+                "citationCount": w.get("cited_by_count", 0),
+                "citationStyles": {"bibtex": _make_bibtex(w, names, venue)},
+            }
+        )
+    time.sleep(0.3)
+    return papers
